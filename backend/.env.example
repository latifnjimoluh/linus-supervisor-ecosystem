############################
# 🟢 APPLICATION
############################
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=45000

############################
# 🌐 CORS
############################
# Ajoute l’URL du front de prod si besoin, séparée par une virgule
# ex: CORS_ORIGINS=http://localhost:3001,https://linusupervisor-front.onrender.com
CORS_ORIGINS=http://localhost:3001

############################
# 🔐 AUTH / JWT
############################
JWT_SECRET=supersecret
JWT_EXPIRES_IN=1000h

############################
# 🗄️ BASE DE DONNÉES (PostgreSQL)
############################
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linsup
DB_USER=postgres
DB_PASS=

# SSL (utile en prod sur Render : mets DB_SSL=true)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Option alternative (si tu préfères une URL unique) :
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

############################
# 📧 EMAIL (Nodemailer)
############################
# Pour Gmail :
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
SMTP_USER=
SMTP_PASS="u"
# MAIL_FROM="Linusupervisor <no-reply@example.com>"

############################
# 🤖 IA / LLM
############################
GEMINI_API_KEY=
MODEL_ID=gemini-1.5-flash
MODEL_FALLBACK_ID=gemini-1.5-flash-8b

############################
# 🧠 RAG / Vector Store
############################
KB_DIR=knowledge_base
VECTOR_DIR=vectorstore
RAG_TOP_K=3
RAG_MIN_SCORE=0.35
RAG_QVARIANTS=2
RAG_ARBITER=rules         # rules | llm | off
RAG_MAX_CONTEXT_CHARS=8000

# Cache embeddings
EMBED_CACHE_SIZE=200
EMBED_CACHE_TTL_MS=1800000   # 30 minutes

# Backend de recherche vectorielle
SEARCH_BACKEND=json          # json | pinecone | chroma (plus tard)

############################
# 🔁 Streaming (si tu utilises un flux token-par-token)
############################
STREAM_SPLIT=char            # char | word | chunk
STREAM_DELAY_MS=0
STREAM_HEARTBEAT_MS=15000

############################
# 📦 FICHIERS / ETAT (si utilisés)
############################
STATUS_JSON_PATH=/tmp/status.json
SERVICES_JSON_PATH=/tmp/services_status.json
INSTANCE_INFO_PATH=/etc/instance-info.conf

############################
# 🖥️ PROXMOX (décommente si nécessaire)
############################
# PROXMOX_API_URL=https://192.168.24.134:8006/api2/json
# PROXMOX_TOKEN_ID=root@pam
# PROXMOX_TOKEN_NAME=delete
# PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
